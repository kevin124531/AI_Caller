# Retell AI
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here
RETELL_FROM_NUMBER=+1234567890
RETELL_WEBHOOK_SECRET=your_webhook_secret_here

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_caller

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-east-1
S3_BUCKET=your-transcript-bucket

# Scheduler (cron expression — default: every Monday at 09:00)
SCHEDULER_CRON=0 9 * * 1

# Contacts CSV path
CONTACTS_CSV_PATH=data/contacts/contacts.csv

# Webhook server
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
